# ==========================================
# 🛠️ GUÍA DE ENTORNO PARA DESARROLLADORES
# ==========================================
# PASO 1: Copia este archivo y renómbralo a `.env.local`
# PASO 2: Asegúrate de tener Docker abierto y levanta la BD con `docker-compose up -d`
# PASO 3: Ejecuta `npm run dev`

# URI para conectar a la base de datos de Docker local
MONGODB_URI=mongodb://localhost:27019/motivem-dataBase
# Secreto aleatorio para encriptar los JWT en entorno local
JWT_SECRET=escribe_aqui_una_contraseña_aleatoria_para_probar_en_local

# ==========================================
# 🚀 PRODUCCIÓN (Vercel)
# ==========================================
# Las variables reales de Producción (Atlas) NO DEBEN ponerse nunca aquí.
# Cuando vayas a desplegar la web online, introdúcelas directamente 
# en el panel web de Vercel (Project > Settings > Environment Variables).
